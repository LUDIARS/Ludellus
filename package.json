{
  "name": "ludellus",
  "version": "0.0.1",
  "private": true,
  "description": "LUDIARS 知育アプリ — Claude 製モックアップを軽量に動かし、 入力動態を学習分析に回すローカルアプリ",
  "main": "dist/main/index.js",
  "type": "commonjs",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "serve": "npx --yes http-server . -p 8080 -c-1 --cors",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "cap:sync": "cap sync",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios",
    "cap:init": "cap add android && cap add ios"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/screen-orientation": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/cli": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@types/node": "^20.12.0",
    "electron": "^31.0.0",
    "typescript": "^5.4.0"
  }
}
